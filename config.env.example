# Kiro-to-IM Bridge Configuration
# Copy to ~/.kiro-to-im/config.env and edit

# Enabled channels (comma-separated: telegram,discord,feishu,qq)
KTI_ENABLED_CHANNELS=telegram

# Default working directory for Kiro agent sessions
KTI_DEFAULT_WORKDIR=/path/to/your/project

# Default model (optional -- inherits from Kiro's own default if not set)
# KTI_DEFAULT_MODEL=

# Default mode (code, plan, ask)
KTI_DEFAULT_MODE=code

# ── Kiro CLI ──
# Path to kiro-cli executable (optional -- auto-detected from PATH if not set)
# KTI_KIRO_CLI_PATH=/path/to/kiro-cli

# kiro-cli arguments (comma-separated, default: acp)
# KTI_KIRO_ARGS=acp,--agent,lark

# Worker pool size (number of kiro-cli processes, default: 4)
# Requests are routed to workers via consistent hash on session ID
# KTI_KIRO_POOL_SIZE=4

# ── Kiro Authentication ──
# kiro-cli stores auth tokens in a SQLite database (NOT plain text files):
#   macOS:   ~/Library/Application Support/kiro-cli/data.sqlite3
#   Linux:   ~/.local/share/kiro-cli/data.sqlite3
#   Windows: %APPDATA%/kiro-cli/data.sqlite3
#
# Choose ONE of the following methods:
#
# Method 1: Pre-authenticate via CLI (recommended for desktop)
#   Run `kiro-cli auth login` before starting the bridge.
#   Tokens are stored in the SQLite database and refreshed automatically.
#   No config needed here — just make sure kiro-cli is logged in.
#
# Method 2: AWS IAM credentials (recommended for servers/CI)
#   Set these in config.env and they'll be forwarded to kiro-cli:
# KTI_AWS_ACCESS_KEY_ID=AKIA...
# KTI_AWS_SECRET_ACCESS_KEY=your-secret-key
# KTI_AWS_SESSION_TOKEN=optional-session-token
# KTI_AWS_REGION=us-east-1
#
# Method 3: AWS SSO profile
#   Run `aws sso login --profile your-profile` before starting the bridge.
# KTI_AWS_PROFILE=your-sso-profile
#
# Auth method hint (auto, cli, aws-credentials, aws-sso). Default: auto
# KTI_KIRO_AUTH_METHOD=auto

# ── Telegram ──
KTI_TG_BOT_TOKEN=your-telegram-bot-token
# Chat ID for authorization (at least one of CHAT_ID or ALLOWED_USERS is required)
# Get it: send a message to the bot, then visit https://api.telegram.org/botYOUR_TOKEN/getUpdates
KTI_TG_CHAT_ID=your-chat-id
# KTI_TG_ALLOWED_USERS=user_id_1,user_id_2

# ── Discord ──
# KTI_DISCORD_BOT_TOKEN=your-discord-bot-token
# KTI_DISCORD_ALLOWED_USERS=user_id_1,user_id_2
# KTI_DISCORD_ALLOWED_CHANNELS=channel_id_1
# KTI_DISCORD_ALLOWED_GUILDS=guild_id_1

# ── Feishu / Lark ──
# KTI_FEISHU_APP_ID=your-app-id
# KTI_FEISHU_APP_SECRET=your-app-secret
# KTI_FEISHU_DOMAIN=https://open.feishu.cn
# KTI_FEISHU_ALLOWED_USERS=user_id_1,user_id_2

# ── QQ ──
# Required: obtain from https://q.qq.com/qqbot/openclaw
# KTI_QQ_APP_ID=your-qq-app-id
# KTI_QQ_APP_SECRET=your-qq-app-secret
# KTI_QQ_ALLOWED_USERS=openid_1,openid_2
# KTI_QQ_IMAGE_ENABLED=true
# KTI_QQ_MAX_IMAGE_SIZE=20

# ── Permission ──
# Auto-approve all tool permission requests without user confirmation.
# Only enable this in trusted, access-controlled environments.
# KTI_AUTO_APPROVE=true
