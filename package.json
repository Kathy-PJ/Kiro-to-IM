{
  "name": "kiro-to-im",
  "version": "0.1.0",
  "description": "Kiro Skill: Bridge IM platforms (Telegram, Discord, Feishu, QQ) to Kiro AI agent via ACP protocol",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "postinstall": "node scripts/patch-cardkit.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/main.ts",
    "test": "KTI_HOME=$(mktemp -d) node --test --import tsx --test-timeout=15000 src/__tests__/*.test.ts"
  },
  "dependencies": {
    "claude-to-im": "github:op7418/claude-to-im"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
