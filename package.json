{
  "name": "kiro-to-im",
  "version": "2.0.0",
  "description": "Bridge IM platforms (Feishu, Discord, Telegram, QQ) to Kiro AI agent via ACP protocol — acp-link architecture",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/main.ts",
    "test": "KTI_HOME=$(mktemp -d) node --test --import tsx --test-timeout=15000 src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "ws": "^8.18.0",
    "discord.js": "^14.16.0",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/ws": "^8.5.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
